# ──────────────────────────────────────────────────────────────────────────────
# Autoflow Community — Configuration
#
# 1. Remplissez toutes les valeurs marquées CHANGE_ME
# 2. Générez AWX_SECRET_KEY avec : openssl rand -hex 32
# 3. Obtenez DOCKER_GID avec     : getent group docker | cut -d: -f3
# 4. Lancez : docker compose up -d
# 5. Accédez à AWX               : http://localhost:${AWX_HTTP_PORT}
# ──────────────────────────────────────────────────────────────────────────────

# ── Image AWX patchée ─────────────────────────────────────────────────────────
AWX_VERSION=24.6.1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=awx
POSTGRES_USER=awx
POSTGRES_PASSWORD=CHANGE_ME_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── AWX ───────────────────────────────────────────────────────────────────────
# Compte administrateur créé automatiquement au premier démarrage
AWX_ADMIN_USER=admin
AWX_ADMIN_PASSWORD=CHANGE_ME_admin_password
AWX_ADMIN_EMAIL=admin@example.com

# Clé secrète Django — NE PAS réutiliser entre environnements
# Générez avec : openssl rand -hex 32
AWX_SECRET_KEY=CHANGE_ME_secret_key_32_chars_minimum

# Port HTTP exposé sur l'hôte (accès via http://localhost:AWX_HTTP_PORT)
AWX_HTTP_PORT=8080

# ── Docker ────────────────────────────────────────────────────────────────────
# GID du groupe docker sur l'hôte — permet à receptor d'accéder au socket
# Obtenez la valeur avec : getent group docker | cut -d: -f3
DOCKER_GID=998
